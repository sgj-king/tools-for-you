# Environment configuration
# Copy to .env and fill in your values

# App
APP_NAME=Tools For You
DEBUG=true
VERSION=1.0.0

# Database (SQLite for development)
DATABASE_URL=sqlite:///./it_tools.db
# For production: postgresql://user:password@localhost/it_tools

# JWT Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI API (NVIDIA NIM)
AI_API_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=nvapi-your-key-here
AI_MODEL=z-ai/glm5

# GitHub API (optional, for syncing)
GITHUB_TOKEN=

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
